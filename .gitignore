tmp/

# Development workflow state
.develop/

# Scratch working directory (ephemeral review artifacts, panel transcripts, etc.)
.scratch/

# Agent worktrees (ephemeral, created by subagent sessions)
.claude/worktrees/

# Cross-session handoff state (managed by /handoff skill, machine-local)
.claude/projects/

# Handoff drafts and panel discussion transcripts (ephemeral)
.handoffs/
.panels/

# Release state (ephemeral, created by /release skill)
.release-pending.yml

# bv (beads viewer) local config and caches
.bv/
.beads/.bv.lock

# Local-only session/runtime state (large, contains absolute paths and
# personal session metadata that should not ship to a public repo)
.beads/daemon.log
.wolf/memory.md
.wolf/token-ledger.json
