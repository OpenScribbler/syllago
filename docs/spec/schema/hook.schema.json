{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syllago.dev/spec/hooks/1.0/hook.schema.json",
  "title": "Hook Canonical Format",
  "description": "Canonical interchange format for AI coding tool hooks (hooks/1.0).",
  "type": "object",
  "required": ["spec", "hooks"],
  "additionalProperties": true,
  "properties": {
    "spec": {
      "type": "string",
      "pattern": "^hooks/\\d+\\.\\d+$",
      "description": "Specification version identifier (e.g. \"hooks/1.0\")."
    },
    "hooks": {
      "type": "array",
      "minItems": 1,
      "description": "Non-empty array of hook definitions.",
      "items": {
        "$ref": "#/$defs/hookDefinition"
      }
    }
  },
  "$defs": {
    "hookDefinition": {
      "type": "object",
      "required": ["event", "handler"],
      "additionalProperties": true,
      "properties": {
        "event": {
          "type": "string",
          "description": "Canonical event name from the Event Registry.",
          "examples": [
            "before_tool_execute",
            "after_tool_execute",
            "session_start",
            "session_end",
            "before_prompt",
            "agent_stop"
          ]
        },
        "matcher": {
          "$ref": "#/$defs/matcher",
          "description": "Tool matcher expression. When omitted, the hook matches all tools."
        },
        "handler": {
          "$ref": "#/$defs/handler"
        },
        "blocking": {
          "type": "boolean",
          "description": "Whether this hook can prevent the triggering action. Default: false."
        },
        "degradation": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["block", "warn", "exclude"]
          },
          "description": "Per-capability fallback strategies. Keys are capability identifiers."
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Informational list of capability identifiers used by this hook."
        },
        "provider_data": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          },
          "description": "Opaque provider-specific data keyed by provider slug."
        }
      }
    },
    "matcher": {
      "oneOf": [
        {
          "type": "string",
          "description": "Bare string: canonical tool name from the Tool Vocabulary."
        },
        {
          "$ref": "#/$defs/patternMatcher"
        },
        {
          "$ref": "#/$defs/mcpMatcher"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/patternMatcher" },
              { "$ref": "#/$defs/mcpMatcher" }
            ]
          },
          "description": "Array of matchers (OR semantics)."
        }
      ]
    },
    "patternMatcher": {
      "type": "object",
      "required": ["pattern"],
      "additionalProperties": true,
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Regular expression matched against the provider-native tool name."
        }
      }
    },
    "mcpMatcher": {
      "type": "object",
      "required": ["mcp"],
      "additionalProperties": true,
      "properties": {
        "mcp": {
          "type": "object",
          "required": ["server"],
          "additionalProperties": true,
          "properties": {
            "server": {
              "type": "string",
              "description": "MCP server name."
            },
            "tool": {
              "type": "string",
              "description": "MCP tool name. When omitted, matches all tools on the server."
            }
          }
        }
      }
    },
    "handler": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "description": "Handler type (e.g. \"command\", \"http\", \"prompt\", \"agent\").",
          "examples": ["command", "http", "prompt", "agent"]
        },
        "command": {
          "type": "string",
          "description": "Shell command or script path. Required when type is \"command\"."
        },
        "platform": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "windows": {
              "type": "string",
              "description": "Windows-specific command override."
            },
            "linux": {
              "type": "string",
              "description": "Linux-specific command override."
            },
            "osx": {
              "type": "string",
              "description": "macOS-specific command override."
            }
          }
        },
        "cwd": {
          "type": "string",
          "description": "Working directory relative to project root."
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables passed to the hook process."
        },
        "timeout": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum execution time in seconds."
        },
        "async": {
          "type": "boolean",
          "description": "Whether the hook runs asynchronously (fire-and-forget). Default: false."
        }
      }
    }
  }
}
