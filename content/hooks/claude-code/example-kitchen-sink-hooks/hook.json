{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Pre-tool check: validating Bash command'",
            "timeout": 5000,
            "statusMessage": "Validating shell command...",
            "async": false
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "command": "Evaluate whether this tool invocation is safe and appropriate. Respond with JSON: {\"decision\": \"allow\"} or {\"decision\": \"deny\", \"reason\": \"...\"}",
            "timeout": 15000,
            "statusMessage": "AI safety check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Post-edit: running linter on changed files'",
            "timeout": 10000,
            "statusMessage": "Running linter...",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Post-tool telemetry placeholder'",
            "timeout": 3000,
            "statusMessage": "Logging tool usage...",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Notification received'",
            "timeout": 2000,
            "statusMessage": "Processing notification..."
          }
        ]
      }
    ]
  }
}
